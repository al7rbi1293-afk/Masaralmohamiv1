{
  "name": "sijil-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @masar/web",
    "build:all": "npm run build --workspaces --if-present",
    "mobile:start": "npm run start --workspace @masar/mobile",
    "mobile:android": "npm run android --workspace @masar/mobile",
    "mobile:ios": "npm run ios --workspace @masar/mobile",
    "mobile:web": "npm run web --workspace @masar/mobile",
    "mobile:testflight": "npx eas-cli build --platform ios --profile production --local false",
    "mobile:testflight:submit": "npx eas-cli submit --platform ios --profile production",
    "pretest": "npm run prisma:generate --workspace @sijil/api",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspace @masar/web",
    "test:rls": "tsx scripts/rls-smoke-test.ts",
    "test:copilot:rls": "tsx scripts/copilot-rls-smoke-test.ts",
    "migrate:legacy-users": "tsx scripts/migrate-legacy-masar-users.ts"
  },
  "devDependencies": {
    "tsx": "^4.7.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
