{
  "name": "@masar/mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo start",
    "start:clear": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo start --clear",
    "android": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo run:android",
    "ios": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo run:ios",
    "web": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo start --web",
    "ios:store": "EXPO_NO_METRO_WORKSPACE_ROOT=1 npx eas-cli build --platform ios --profile storeIos --non-interactive",
    "ios:submit": "EXPO_NO_METRO_WORKSPACE_ROOT=1 npx eas-cli submit --platform ios --profile storeIos"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "dependencies": {
    "@expo-google-fonts/ibm-plex-sans-arabic": "^0.4.2",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native/virtualized-lists": "^0.81.5",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/core": "^7.16.2",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.6",
    "@react-navigation/routers": "^7.5.3",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.12",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-freeze": "^1.0.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "use-latest-callback": "^0.2.6",
    "use-sync-external-store": "^1.6.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
