  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.57.4",
    "bullmq": "^5.8.3",
    "ioredis": "^5.4.1",
    "mammoth": "^1.8.0",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
